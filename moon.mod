name = "bobzhang/html_parser"

version = "0.1.7"

import {
  "moonbitlang/async@0.19.0",
}

readme = "README.mbt.md"

repository = "https://github.com/bobzhang/html_parser"

license = "Apache-2.0"

keywords = [ "html", "parser", "sanitizer", "dom", "markdown" ]

description = "MoonBit HTML parser and sanitizer ported from JustHTML."

preferred_target = "native"

warnings = "+test_unqualified_package+unnecessary_annotation+missing_doc+deprecated+unused_optional_argument"
