fn legacy_named_entity_value(name : StringView) -> String? {
  match name {
    "gt" => Some(">")
    "lt" => Some("<")
    "amp" => Some("&")
    "quot" => Some("\"")
    "nbsp" => Some("\u{00A0}")
    "AMP" => Some("&")
    "QUOT" => Some("\"")
