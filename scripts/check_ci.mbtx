///|
fn package_dirs_from_tracked(tracked : ArrayView[String]) -> Array[String] {
  let dirs : Array[String] = []
  for path in tracked {
    if path == "moon.pkg" {
      if !dirs.contains(".") {
        dirs.push(".")
      }
    } else {
      match path.strip_suffix("/moon.pkg") {
        Some(dir) => {
          let owned = dir.to_owned()
          if !dirs.contains(owned) {
            dirs.push(owned)
          }
        }
        None => ()
      }
    }
  }
  sort_strings(dirs)
  dirs
}

///|
fn package_prefixes_from_tracked(tracked : ArrayView[String]) -> Array[String] {
  let prefixes : Array[String] = []
  for dir in package_dirs_from_tracked(tracked) {
    let prefix = if dir == "." { "" } else { dir + "/" }
    if !prefixes.contains(prefix) {
      prefixes.push(prefix)
    }
  }
  prefixes
}

///|
fn package_has_source(tracked : ArrayView[String], prefix : String) -> Bool {
  for path in tracked {
    let rest = match path.strip_prefix(prefix) {
      Some(rest) => rest
      None => continue
    }
    if !rest.contains("/") && (path.has_suffix(".mbt") || path.has_suffix(".mbt.md")) {
      return true
    }
  }
  false
}

///|
fn parent_prefix(path : String) -> String {
  match path.rev_split_once("/") {
    Some((parent, _)) => parent.to_owned() + "/"
    None => ""
  }
}

///|
fn is_source_like(path : String) -> Bool {
  path.has_suffix(".mbt") || path.has_suffix(".mbt.md") || path.has_suffix(".mbti") ||
  path.has_suffix(".c")
}

///|
fn is_forbidden_tracked_path(path : String) -> Bool {
  for prefix in [".mooncakes/", ".moonagent/", ".repos/", "_build/", "__pycache__/"] {
    if path.has_prefix(prefix) {
      return true
    }
  }
  path == ".DS_Store" || path.has_suffix("/.DS_Store") || path.contains("/__pycache__/") ||
  path.has_suffix(".pyc")
}

