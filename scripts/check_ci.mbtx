///|
async fn run_check_release_version() -> Int {
  let metadata = match read_module_metadata() {
    Some(value) => value
    None => return 1
  }
  let version = match metadata_string(metadata, "version") {
    Some(value) => value
    None => {
      eprintln("\{metadata.path} field 'version' must be a non-empty string")
      return 1
    }
  }
  let cli_files = git_ls_files(["cli/*.mbt"])
  let cli_sources = @buffer.new()
  for path in cli_files {
    match read_text(path) {
      Some(text) => cli_sources.write_string("\{text}\n")
      None => {
        eprintln("could not read \{path}")
        return 1
      }
    }
  }
  let cli_version = find_cli_version(cli_sources.to_string())
  match cli_version {
    None => {
      eprintln("could not find cli_version()")
      return 1
    }
    Some(value) => if value != version {
      eprintln("cli_version \{value} != module version \{version}")
      return 1
    }
  }
  let cli_test = match read_text("cli_test.mbt") {
    Some(value) => value
    None => {
      eprintln("cli_test.mbt does not exist")
      return 1
    }
  }
  let expected_test = "assert_eq(version.stdout, \"justhtml \{version}\\n\")"
  if !cli_test.contains(expected_test) {
    eprintln("CLI --version test does not assert the module version")
    return 1
  }
  0
}

///|
async fn run_check_validation_inventory() -> Int {
  let expected_scripts = ["scripts/check_ci.mbtx"]
  let actual_scripts = git_ls_files(["scripts/*"])
  let mut ok = true
  ok = require_all_tracked(expected_scripts, actual_scripts, "expected MoonBit script is not tracked: ") && ok
  for path in actual_scripts {
    if path.has_suffix(".sh") || path.has_suffix(".py") {
      eprintln("tracked script must not use shell or Python extension: \{path}")
      ok = false
    } else if !path.has_suffix(".mbtx") {
      eprintln("tracked script has unsupported extension: \{path}")
      ok = false
    }
  }
  let ci_text = match read_text("scripts/check_ci.mbtx") {
    Some(value) => value
    None => return 1
  }
  for command in validation_commands() {
    ok = require_text(ci_text, command, "scripts/check_ci.mbtx") && ok
  }
  ok = require_text(
    ci_text,
    "\"cram\", \"test\", \"--release\", \"tests/cram\"",
    "scripts/check_ci.mbtx",
  ) && ok
  if ok { 0 } else { 1 }
}

///|
async fn run_check_github_workflows() -> Int {
  let expected_workflows = [
    ".github/workflows/ci.yml",
    ".github/workflows/copilot-setup-steps.yml",
    ".github/workflows/nightly.yml",
  ]
  let actual_workflows = git_ls_files([".github/workflows/*.yml"])
  let mut ok = true
  ok = require_all_tracked(expected_workflows, actual_workflows, "expected GitHub workflow is not tracked: ") && ok
  for path in actual_workflows {
    if !expected_workflows.contains(path) {
      eprintln("tracked GitHub workflow is missing from validation: \{path}")
      ok = false
    }
  }
  let workflow = ".github/workflows/ci.yml"
  let text = match read_text(workflow) {
    Some(value) => value
    None => {
      eprintln(".github/workflows/ci.yml does not exist")
      return 1
    }
  }
  let main_branch_needle =
    $|branches:
    $|      - main
  let read_permissions_needle =
    $|permissions:
    $|      contents: read
  for needle in [
    "name: CI",
    "pull_request:",
    "workflow_dispatch:",
    main_branch_needle,
    read_permissions_needle,
    "curl -fsSL https://cli.moonbitlang.com/install/unix.sh | bash",
    "echo \"$HOME/.moon/bin\" >> \"$GITHUB_PATH\"",
    "run: moon version --all",
    "run: moon update",
    "run: moon run --target native scripts/check_ci.mbtx --skip-without-credentials",
  ] {
    ok = require_text(text, needle, workflow) && ok
  }
  let check_ci_refs = count_occurrences(text, "scripts/check_ci.mbtx")
  if check_ci_refs != 1 {
    eprintln(
      ".github/workflows/ci.yml must invoke scripts/check_ci.mbtx exactly once, found \{check_ci_refs}",
    )
    ok = false
  }
  for needle in [
    "run: moon check",
    "run: moon fmt",
    "run: moon test",
    "run: moon coverage",
    "run: moon publish",
  ] {
    ok = require_absent(text, needle, workflow) && ok
  }
  let nightly = ".github/workflows/nightly.yml"
  match read_text(nightly) {
    None => {
      eprintln(".github/workflows/nightly.yml does not exist")
      ok = false
    }
    Some(nightly_text) => {
      for needle in [
        "name: Nightly CI",
        "pull_request:",
        "workflow_dispatch:",
        main_branch_needle,
        read_permissions_needle,
        "curl -fsSL https://cli.moonbitlang.com/install/unix.sh | bash -s -- nightly",
        "echo \"$HOME/.moon/bin\" >> \"$GITHUB_PATH\"",
        "run: moon version --all",
        "run: moon update",
        "run: moon run --target native scripts/check_ci.mbtx --skip-without-credentials",
      ] {
        ok = require_text(nightly_text, needle, nightly) && ok
      }
      let nightly_check_ci_refs = count_occurrences(
        nightly_text,
        "scripts/check_ci.mbtx",
      )
      if nightly_check_ci_refs != 1 {
        eprintln(
          ".github/workflows/nightly.yml must invoke scripts/check_ci.mbtx exactly once, found \{nightly_check_ci_refs}",
        )
        ok = false
      }
    }
  }
  let copilot = ".github/workflows/copilot-setup-steps.yml"
  match read_text(copilot) {
    None => {
      eprintln(".github/workflows/copilot-setup-steps.yml does not exist")
      ok = false
    }
    Some(copilot_text) => for needle in [
      "name: \"Copilot Setup Steps\"",
      "workflow_dispatch:",
      "push:\n    paths:\n      - .github/workflows/copilot-setup-steps.yml",
      "pull_request:\n    paths:\n      - .github/workflows/copilot-setup-steps.yml",
      "copilot-setup-steps:",
      "runs-on: ubuntu-latest",
      "permissions:",
      "contents: read",
      "uses: actions/checkout@v5",
      "curl -fsSL https://cli.moonbitlang.com/install/unix.sh | bash",
      "echo \"$HOME/.moon/bin\" >> \"$GITHUB_PATH\"",
      "moon version --all",
      "moon update",
    ] {
      ok = require_text(copilot_text, needle, copilot) && ok
    }
  }
  if ok { 0 } else { 1 }
}

///|
async fn run_check_source_layout() -> Int {
  let tracked = git_ls_files([])
  let mut ok = true
  ok = require_all_tracked(required_top_level_files(), tracked, "required top-level project file is not tracked: ") && ok
  if !tracked.contains("moon.mod") && !tracked.contains("moon.mod.json") {
    eprintln("required top-level project file is not tracked: moon.mod or moon.mod.json")
    ok = false
  }
  ok = require_all_tracked(required_root_modules(), tracked, "expected root package module is not tracked: ") && ok
  ok = require_all_tracked(required_fixture_files(), tracked, "expected vendored fixture is not tracked: ") && ok
  let package_dirs = package_dirs_from_tracked(tracked)
  if !package_dirs.contains(".") {
    eprintln("root package moon.pkg is not tracked")
    ok = false
  }
  for package_dir in package_dirs {
    let prefix = if package_dir == "." { "" } else { "\{package_dir}/" }
    let interface_path = "\{prefix}pkg.generated.mbti"
    if !tracked.contains(interface_path) {
      eprintln("package \{package_dir} must track \{interface_path}")
      ok = false
    }
    if !package_has_source(tracked, prefix) {
      eprintln("package \{package_dir} must contain tracked MoonBit source")
      ok = false
    }
  }
  let package_prefixes = package_prefixes_from_tracked(tracked)
  for path in tracked {
    if is_source_like(path) && !package_prefixes.contains(parent_prefix(path)) {
      eprintln("tracked source file is outside a MoonBit package: \{path}")
      ok = false
    }
    if is_forbidden_tracked_path(path) {
      eprintln("generated/reference checkout path must not be tracked: \{path}")
      ok = false
    }
  }
  if ok { 0 } else { 1 }
}

///|
async fn run_check_test_inventory() -> Int {
  let expected_count = 845
  let expected_sha256 = "5fe26aafb97fbca24637fefdafc2a2917449d37d780ae6f624745f250b77a4d7"
  let inventory : Array[String] = []
  for path in git_ls_files(["*.mbt", "*.mbt.md"]) {
    match read_text(path) {
      None => {
        eprintln("could not read \{path}")
        return 1
      }
      Some(text) => {
        for name in test_declarations(text) {
          inventory.push("\{path}:\{name}")
        }
      }
    }
  }
  sort_strings(inventory)
  let observed_count = inventory.length()
  let observed_sha256 = sha256_text(join_lines(inventory))
  let mut ok = true
  if observed_count != expected_count {
    eprintln(
      "MoonBit test inventory count changed: expected \{expected_count}, observed \{observed_count}",
    )
    ok = false
  }
  let duplicates = duplicate_items(inventory)
  if !duplicates.is_empty() {
    eprintln("MoonBit test inventory contains duplicate declarations:")
    for item in duplicates {
      eprintln("  \{item}")
    }
    ok = false
  }
  if observed_sha256 != expected_sha256 {
    eprintln(
      "MoonBit test inventory hash changed: expected \{expected_sha256}, observed \{observed_sha256}",
    )
    eprintln("Review the test declaration changes before updating this guard.")
    ok = false
  }
  if ok { 0 } else { 1 }
}

///|
async fn run_check_moonbit_style() -> Int {
  let mut ok = true
  for path in git_ls_files(["*.mbt"]) {
    match read_text(path) {
      None => {
        eprintln("could not read \{path}")
        ok = false
      }
      Some(text) => if !text.contains("///|") {
        eprintln("\{path} must use block-style separators marked by '///|'")
        ok = false
      }
    }
  }
  if ok { 0 } else { 1 }
}

///|
async fn run_check_gitignore() -> Int {
  let text = match read_text(".gitignore") {
    Some(value) => value
    None => {
      eprintln(".gitignore does not exist")
      return 1
    }
  }
  let ignored = gitignore_rules(text)
  let mut ok = true
  for rule in [".DS_Store", "_build/", ".mooncakes/", ".moonagent/", ".repos/", "__pycache__/"] {
    if !ignored.contains(rule) {
      eprintln(".gitignore must contain \{rule}")
      ok = false
    }
  }
  if ok { 0 } else { 1 }
}

///|
async fn run_check_githooks() -> Int {
  let expected = [".githooks/README.md", ".githooks/pre-commit"]
  let actual = git_ls_files([".githooks/*"])
  let mut ok = true
  ok = require_all_tracked(expected, actual, "expected Git hook file is not tracked: ") && ok
  for path in actual {
    if !expected.contains(path) {
      eprintln("tracked Git hook file is missing from validation: \{path}")
      ok = false
    }
  }
  let hook = ".githooks/pre-commit"
  let hook_text = match read_text(hook) {
    Some(value) => value
    None => {
      eprintln(".githooks/pre-commit does not exist")
      ok = false
      ""
    }
  }
  if !@fs.can_execute(hook) {
    eprintln(".githooks/pre-commit must be executable")
    ok = false
  }
  for needle in [
    "#!/usr/bin/env bash",
    "set -euo pipefail",
    "git rev-parse --show-toplevel",
    "moon run --target native scripts/check_ci.mbtx --skip-without-credentials",
  ] {
    ok = require_text(hook_text, needle, hook) && ok
  }
  let readme = ".githooks/README.md"
  let readme_text = match read_text(readme) {
    Some(value) => value
    None => {
      eprintln(".githooks/README.md does not exist")
      ok = false
      ""
    }
  }
  for needle in [
    "git config core.hooksPath .githooks",
    "moon run --target native scripts/check_ci.mbtx --skip-without-credentials",
  ] {
    ok = require_text(readme_text, needle, readme) && ok
  }
  if ok { 0 } else { 1 }
}

///|
async fn run_check_migration_docs() -> Int {
  let mut ok = true
  for doc in migration_doc_needles() {
    let (path, needles) = doc
    match read_text(path) {
      None => {
        eprintln("required migration document is missing: \{path}")
        ok = false
      }
      Some(text) => for needle in needles {
        ok = require_text_collapsed(text, needle, path) && ok
      }
    }
  }
  if ok { 0 } else { 1 }
}

///|
async fn run_check_fixture_sync(require_reference : Bool) -> Int {
  let reference_root = match @env.get_env_var("JUSTHTML_REFERENCE_ROOT") {
    Some(value) => value
    None => ".repos/justhtml"
  }
  if !@fs.exists(reference_root) {
    let message = "Skipping fixture sync check because reference checkout is absent: \{reference_root}"
    if require_reference {
      eprintln(message)
      return 1
    }
    write_stdout("\{message}\n")
    return 0
  }
  let mut ok = true
  for pair in fixture_pairs() {
    let (local_rel, reference_rel) = pair
    let local_path = "tests/fixtures/justhtml/\{local_rel}"
    let reference_path = "\{reference_root}/\{reference_rel}"
    match read_bytes(local_path) {
      None => {
        eprintln("missing vendored fixture: \{local_path}")
        ok = false
        continue
      }
      Some(local_data) => match read_bytes(reference_path) {
        None => {
          eprintln("missing reference fixture: \{reference_path}")
          ok = false
        }
        Some(reference_data) => if local_data != reference_data {
          eprintln("vendored fixture differs from reference: \{local_rel}")
          ok = false
        }
      }
    }
  }
  if ok { 0 } else { 1 }
}

///|
async fn run_check_fixture_manifest() -> Int {
  let tracked = git_ls_files([
    "tests/fixtures/justhtml/**", "tests/fixtures/html5lib-tests/**",
  ])
  let manifest = fixture_manifest()
  let expected : Array[String] = []
  for entry in manifest {
    let (path, _, _) = entry
    expected.push(path)
  }
  let mut ok = true
  ok = require_all_tracked(expected, tracked, "fixture manifest entry is not tracked: ") && ok
  for path in tracked {
    if !expected.contains(path) {
      eprintln("tracked fixture is missing from manifest: \{path}")
      ok = false
    }
  }
  for entry in manifest {
    let (path, expected_size, expected_sha256) = entry
    match read_bytes(path) {
      None => {
        eprintln("fixture manifest entry is missing from disk: \{path}")
        ok = false
      }
      Some(data) => {
        let actual_sha256 = @crypto.bytes_to_hex_string(@crypto.sha256(data))
        if data.length() != expected_size {
          eprintln(
            "fixture size changed for \{path}: \{data.length()} != \{expected_size}",
          )
          ok = false
        }
        if actual_sha256 != expected_sha256 {
          eprintln(
            "fixture sha256 changed for \{path}: \{actual_sha256} != \{expected_sha256}",
          )
          ok = false
        }
      }
    }
  }
  if ok { 0 } else { 1 }
}

///|
async fn run_check_package_metadata() -> Int {
  let metadata = match read_module_metadata() {
    Some(value) => value
    None => return 1
  }
  let mut ok = true
  let name = expect_metadata_string(metadata, "name")
  let version = expect_metadata_string(metadata, "version")
  let readme = expect_metadata_string(metadata, "readme")
  let repository = expect_metadata_string(metadata, "repository")
  let license_id = expect_metadata_string(metadata, "license")
  let description = expect_metadata_string(metadata, "description")
  ok = name is Some(_) && version is Some(_) && readme is Some(_) && repository is Some(_) &&
    license_id is Some(_) && description is Some(_) && ok
  ok = check_keywords(metadata) && ok
  let mut readme_text = ""
  match (name, version, readme) {
    (Some(package_name), Some(package_version), Some(readme_path)) => {
      if !valid_package_name(package_name) {
        eprintln("package name \{package_name} must use owner/package form")
        ok = false
      }
      if !valid_semver(package_version) {
        eprintln("version \{package_version} must look like a semantic version")
        ok = false
      }
      if invalid_repo_relative_path(readme_path) {
        eprintln("readme path \{readme_path} must stay inside the repository")
        ok = false
      } else {
        match read_text(readme_path) {
          None => {
            eprintln("readme path \{readme_path} does not exist")
            ok = false
          }
          Some(text) => {
            readme_text = text
            match read_text("README.md") {
              None => {
                eprintln("README.md must exist for GitHub rendering")
                ok = false
              }
              Some(github_readme) => if github_readme != readme_text {
                eprintln("README.md must resolve to or match the configured Mooncakes readme \{readme_path}")
                ok = false
              }
            }
          }
        }
      }
      if !readme_text.is_empty() {
        let expected_heading = "# \{package_name}"
        if !first_lines(readme_text, 5).contains(expected_heading) {
          eprintln("README must start with heading \{expected_heading}")
          ok = false
        }
        let expected_install = "moon add \{package_name}"
        if !readme_text.contains(expected_install) {
          eprintln("README must document \{expected_install}")
          ok = false
        }
        let expected_import = "\"\{package_name}\""
        if !readme_text.contains(expected_import) {
          eprintln("README must show import path \{expected_import}")
          ok = false
        }
      }
    }
    _ => ok = false
  }
  match (name, repository) {
    (Some(package_name), Some(repo)) => {
      let expected_repository = "https://github.com/\{package_name}"
      if repo != expected_repository {
        eprintln("repository \{repo} != expected \{expected_repository}")
        ok = false
      }
    }
    _ => ()
  }
  match license_id {
    Some(value) => {
      if value != "Apache-2.0" {
        eprintln("license \{value} must be 'Apache-2.0'")
        ok = false
      }
      match read_text("LICENSE") {
        None => {
          eprintln("LICENSE file does not exist")
          ok = false
        }
        Some(text) => if !text.contains("Apache License") || !text.contains("Version 2.0") {
          eprintln("LICENSE file does not contain Apache License 2.0 text")
          ok = false
        }
      }
    }
    None => ok = false
  }
  match description {
    Some(value) => if value.length() > 200 {
      eprintln("\{metadata.path} description should stay concise")
      ok = false
    }
    None => ok = false
  }
  ok = check_native_cli_metadata(name) && ok
  if ok { 0 } else { 1 }
}

///|
async fn run_check_publish_archive(archive_arg : String) -> Int {
  let archive = if archive_arg.is_empty() {
    match expected_archive_path() {
      Some(value) => value
      None => return 1
    }
  } else {
    archive_arg
  }
  if !@fs.exists(archive) {
    eprintln("Mooncakes archive does not exist: \{archive}")
    return 1
  }
  let entries = match read_zip_entries(archive) {
    Some(value) => value
    None => return 1
  }
  let names = [ for entry in entries => entry.name ]
  let required = expected_published_files()
  let mut ok = true
  for name in duplicate_items(names) {
    eprintln("Mooncakes archive contains duplicate path: \{name}")
    ok = false
  }
  for path in required {
    if !names.contains(path) {
      eprintln("Mooncakes archive is missing required file: \{path}")
      ok = false
    }
  }
  for name in names {
    if archive_path_unsafe(name) {
      eprintln("Mooncakes archive contains unsafe path: \{name}")
      ok = false
    }
    if archive_path_forbidden(name) {
      eprintln("Mooncakes archive contains non-package path: \{name}")
      ok = false
    }
    if name.contains("/__pycache__/") || name.has_suffix(".pyc") {
      eprintln("Mooncakes archive contains Python bytecode/cache path: \{name}")
      ok = false
    }
  }
  if names.contains("README.md") && names.contains("README.mbt.md") {
    let readme = zip_entry(entries, "README.md")
    let mbt_readme = zip_entry(entries, "README.mbt.md")
    match (readme, mbt_readme) {
      (Some(left), Some(right)) => if left.uncompressed_size != right.uncompressed_size ||
        left.crc32 != right.crc32 {
        eprintln("Mooncakes archive README.md must match README.mbt.md")
        ok = false
      }
      _ => {
        eprintln("failed to read README entries from Mooncakes archive")
        ok = false
      }
    }
  }
  if ok { 0 } else { 1 }
}

///|
async fn run_check_scripts() -> Int {
  let bad_scripts = git_ls_files(["scripts/*.sh", "scripts/*.py"])
  if !bad_scripts.is_empty() {
    eprintln("tracked scripts must be MoonBit .mbtx files, found:")
    for script in bad_scripts {
      eprintln(script)
    }
    return 1
  }
  let tracked_scripts = git_ls_files(["scripts/*"])
  if tracked_scripts.is_empty() {
    eprintln("No tracked scripts found.")
    return 1
  }
  for script in tracked_scripts {
    if script.has_suffix(".mbtx") {
      let code = @process.run(
        "moon",
        ["run", "--target", "native", "--build-only", script],
      )
      if code != 0 {
        return code
      }
    } else {
      eprintln("tracked script has unsupported extension: \{script}")
      return 1
    }
  }
  if !check_bad_option(
    "scripts/check_ci.mbtx",
    "usage: moon run --target native scripts/check_ci.mbtx [--skip-without-credentials]",
  ) {
    return 1
  }
  0
}

///|
async fn run_check_interfaces() -> Int {
  let info_code = @process.run("moon", ["info"])
  if info_code != 0 {
    return info_code
  }
  let interface_files = git_ls_files(["pkg.generated.mbti", "*/pkg.generated.mbti"])
  if interface_files.is_empty() {
    eprintln("No tracked pkg.generated.mbti files found.")
    return 1
  }
  let args = ["diff", "--exit-code", "--"]
  for path in interface_files {
    args.push(path)
  }
  @process.run("git", args)
}

///|
async fn run_check_tests() -> Int {
  let mut code = run_test_target("default", [])
  if code != 0 { return code }
  code = run_test_target("JS", ["--target", "js"])
  if code != 0 { return code }
  run_test_target("native", ["--target", "native"])
}

///|
async fn run_check_coverage() -> Int {
  let minimum_coverage_percent = 90
  let (code, output) = @process.collect_output_merged("moon", ["coverage", "analyze"])
  let text = output.text()
  write_stdout(text)
  if code != 0 {
    return code
  }
  let uncovered = match parse_uncovered_line_count(text) {
    Some(value) => value
    None => {
      eprintln("moon coverage analyze output did not include a parseable uncovered-line summary")
      return 1
    }
  }
  let source_lines = match tracked_coverage_source_line_count() {
    Some(value) => value
    None => return 1
  }
  let covered_lines = source_lines - uncovered
  if covered_lines * 100 < source_lines * minimum_coverage_percent {
    eprintln(
      "coverage below \{minimum_coverage_percent}%: \{covered_lines}/\{source_lines} tracked source lines covered",
    )
    1
  } else {
    let message =
      $|Coverage threshold passed: \{covered_lines}/\{source_lines} tracked source lines covered (minimum \{minimum_coverage_percent}%).
      $|
    write_stdout(message)
    0
  }
}

///|
fn parse_uncovered_line_count(text : String) -> Int? {
  if text.contains("All source files are fully covered") {
    return Some(0)
  }
  let prefix = "Total: "
  for raw_line in text.split("\n") {
    let line = raw_line.to_owned()
    let rest = match line.strip_prefix(prefix) {
      Some(value) => value.to_owned()
      None => continue
    }
    match rest.split_once(" uncovered line") {
      Some((count_text, _)) =>
        return parse_non_negative_int(count_text.to_owned())
      None => ()
    }
  }
  None
}

///|
async fn tracked_coverage_source_line_count() -> Int? {
  let mut total = 0
  for path in git_ls_files(["*.mbt"]) {
    if coverage_source_path_is_counted(path) {
      match read_text(path) {
        Some(text) => total += split_lines(text).length()
        None => {
          eprintln("could not read tracked source file for coverage threshold: \{path}")
          return None
        }
      }
    }
  }
  if total == 0 {
    eprintln("coverage threshold could not find tracked source lines")
    None
  } else {
    Some(total)
  }
}

///|
fn coverage_source_path_is_counted(path : String) -> Bool {
  path.has_suffix(".mbt") &&
  !path.has_suffix("_test.mbt") &&
  !path.has_suffix("_wbtest.mbt") &&
  !path.has_prefix("scripts/")
}

