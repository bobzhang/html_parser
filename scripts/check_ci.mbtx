///|
async fn check_keywords(metadata : ModuleMetadata) -> Bool {
  match metadata.keywords {
    None => {
      eprintln(metadata.path + " field 'keywords' must be a non-empty list")
      false
    }
    Some(keywords) => {
      if keywords.is_empty() {
        eprintln(metadata.path + " field 'keywords' must be a non-empty list")
        return false
      }
      let mut ok = true
      for keyword in keywords {
        if keyword.is_empty() {
          ok = false
        }
      }
      if !ok {
        eprintln(metadata.path + " field 'keywords' must contain only non-empty strings")
      }
      ok
    }
  }
}

///|
fn valid_package_name(name : String) -> Bool {
  match name.split_once("/") {
    Some((owner, pkg)) => !owner.is_empty() && !pkg.is_empty() &&
      valid_package_segment(owner.to_owned()) && valid_package_segment(pkg.to_owned())
    None => false
  }
}

///|
fn valid_package_segment(segment : String) -> Bool {
  let allowed = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789_.-"
  for ch in segment.iter() {
    if !allowed.contains_char(ch) {
      return false
    }
  }
  true
}

///|
fn valid_semver(version : String) -> Bool {
  let mut core = version
  match version.split_once("+") {
    Some((left, build)) => {
      if !valid_semver_suffix(build.to_owned()) {
        return false
      }
      core = left.to_owned()
    }
    None => ()
  }
  let mut numeric = core
  match core.split_once("-") {
    Some((left, prerelease)) => {
      if !valid_semver_suffix(prerelease.to_owned()) {
        return false
      }
      numeric = left.to_owned()
    }
    None => ()
  }
  let mut part_count = 0
  for part in numeric.split(".") {
    part_count += 1
    if part_count > 3 {
      return false
    }
    if part.is_empty() {
      return false
    }
    for ch in part.iter() {
      if ch < '0' || ch > '9' {
        return false
      }
    }
  }
  part_count == 3
}

///|
fn valid_semver_suffix(value : String) -> Bool {
  if value.is_empty() {
    return false
  }
  let allowed = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789.-"
  for ch in value.iter() {
    if !allowed.contains_char(ch) {
      return false
    }
  }
  true
}

///|
fn invalid_repo_relative_path(path : String) -> Bool {
  path.has_prefix("/") || path == ".." || path.has_prefix("../") || path.contains("/../") ||
  path.has_suffix("/..")
}

///|
fn first_lines(text : String, count : Int) -> Array[String] {
  let lines : Array[String] = []
  let mut seen = 0
  for line in text.split("\n") {
    if seen >= count {
      break
    }
    lines.push(line.to_owned())
    seen += 1
  }
  lines
}

///|
async fn check_native_cli_metadata(name : String?) -> Bool {
  let cli_pkg = read_text("cmd/main/moon.pkg")
  let cli_main = read_text("cmd/main/main.mbt")
  let mut ok = true
  match (cli_pkg, cli_main) {
    (Some(pkg_text), Some(main_text)) => {
      let package_needles = [
        "supported_targets = \"+native\"",
        "\"is-main\": true",
        "\"moonbitlang/async\"",
        "\"moonbitlang/async/fs\"",
        "\"moonbitlang/async/stdio\"",
      ]
      for needle in package_needles {
        ok = require_text(pkg_text, needle, "cmd/main/moon.pkg") && ok
      }
      ok = require_absent(pkg_text, "\"native-stub\"", "cmd/main/moon.pkg") && ok
      match name {
        Some(package_name) => ok = require_text(pkg_text, "\"" + package_name + "\"", "cmd/main/moon.pkg") && ok
        None => ok = false
      }
      for needle in [
        "async fn main",
        "@html_parser.cli_read_plan(args)",
        "@stdio.stdin.read_all().binary()",
        "@fs.read_file(path).binary()",
        "@fs.write_file(path, content, create_mode=CreateOrTruncate)",
        "@stdio.stdout.write(result.stdout)",
        "@stdio.stderr.write(result.stderr)",
        "extern \"C\" fn exit_process(code : Int) = \"exit\"",
      ] {
        ok = require_text(main_text, needle, "cmd/main/main.mbt") && ok
      }
      ok = require_absent(main_text, "html_parser_cli_", "cmd/main/main.mbt") && ok
    }
    _ => {
      if cli_pkg is None { eprintln("native CLI package does not exist: cmd/main/moon.pkg") }
      if cli_main is None { eprintln("native CLI entrypoint does not exist: cmd/main/main.mbt") }
      ok = false
    }
  }
  ok
}

///|
async fn expected_archive_path() -> String? {
  let metadata = match read_module_metadata() {
    Some(value) => value
    None => return None
  }
  let name = match metadata_string(metadata, "name") {
    Some(value) => value
    None => {
      eprintln(metadata.path + " field 'name' must use owner/package form")
      return None
    }
  }
  let version = match metadata_string(metadata, "version") {
    Some(value) => value
    None => {
      eprintln(metadata.path + " field 'version' must be a non-empty string")
      return None
    }
  }
  match name.split_once("/") {
    Some((owner, pkg)) => Some(
      "_build/publish/" + owner.to_owned() + "-" + pkg.to_owned() + "-" + version + ".zip",
    )
    None => {
      eprintln(metadata.path + " field 'name' must use owner/package form")
      None
    }
  }
}

///|
async fn expected_published_files() -> Array[String] {
  let expected : Array[String] = []
  for path in git_ls_files([]) {
    let name = basename(path)
    let parent = dirname(path)
    if name == "moon.mod" || name == "moon.mod.json" || name == "moon.pkg" || name == "LICENSE" {
      expected.push(path)
    } else if parent == "." && path.has_suffix(".md") {
      expected.push(path)
    } else if path.has_prefix("scripts/") {
      expected.push(path)
    } else if path.has_prefix("tests/fixtures/justhtml/") {
      expected.push(path)
    } else if is_source_like(path) {
      expected.push(path)
    }
  }
  expected
}

///|
fn basename(path : String) -> String {
  match path.rev_split_once("/") {
    Some((_, name)) => name.to_owned()
    None => path
  }
}

///|
fn dirname(path : String) -> String {
  match path.rev_split_once("/") {
    Some((parent, _)) => parent.to_owned()
    None => "."
  }
}

///|
fn archive_path_unsafe(name : String) -> Bool {
  name.has_prefix("/") || ("/" + name).contains("/../")
}

///|
fn archive_path_forbidden(name : String) -> Bool {
  for prefix in [".git/", ".github/", ".githooks/", ".repos/", "_build/", "node_modules/", "__pycache__/"] {
    if name.has_prefix(prefix) {
      return true
    }
  }
  false
}

///|
struct ZipEntry {
  name : String
  crc32 : Int64
  uncompressed_size : Int
}

///|
async fn read_zip_entries(archive : String) -> Array[ZipEntry]? {
  let data = match read_bytes(archive) {
    Some(value) => value
    None => {
      eprintln("failed to read Mooncakes archive: " + archive)
      return None
    }
  }
  let eocd = match find_zip_eocd(data) {
    Some(value) => value
    None => {
      eprintln("Mooncakes archive is missing ZIP end-of-central-directory record")
      return None
    }
  }
  let entry_count = zip_le_u16(data, eocd + 10)
  let central_size = zip_le_u32_int(data, eocd + 12)
  let central_offset = zip_le_u32_int(data, eocd + 16)
  if central_offset < 0 || central_size < 0 ||
    central_offset + central_size > data.length() {
    eprintln("Mooncakes archive has an invalid ZIP central directory range")
    return None
  }
  let entries : Array[ZipEntry] = []
  let mut pos = central_offset
  for _ in 0..<entry_count {
    if pos + 46 > data.length() || zip_le_u32_int(data, pos) != 33639248 {
      eprintln("Mooncakes archive has an invalid ZIP central directory entry")
      return None
    }
    let crc32 = zip_le_u32_i64(data, pos + 16)
    let uncompressed_size = zip_le_u32_int(data, pos + 24)
    let name_len = zip_le_u16(data, pos + 28)
    let extra_len = zip_le_u16(data, pos + 30)
    let comment_len = zip_le_u16(data, pos + 32)
    let name_start = pos + 46
    let next = name_start + name_len + extra_len + comment_len
    if next > data.length() {
      eprintln("Mooncakes archive has a truncated ZIP central directory entry")
      return None
    }
    let name = @utf8.decode_lossy(data.view(start=name_start, end=name_start + name_len))
    entries.push(ZipEntry::{ name, crc32, uncompressed_size })
    pos = next
  }
  Some(entries)
}

///|
fn find_zip_eocd(data : Bytes) -> Int? {
  if data.length() < 22 {
    return None
  }
  let lower = Int::max(0, data.length() - 22 - 65535)
  let mut pos = data.length() - 22
  while pos >= lower {
    if zip_le_u32_int(data, pos) == 101010256 &&
      pos + 22 + zip_le_u16(data, pos + 20) == data.length() {
      return Some(pos)
    }
    pos -= 1
  }
  None
}

///|
fn zip_entry(entries : ArrayView[ZipEntry], name : String) -> ZipEntry? {
  for entry in entries {
    if entry.name == name {
      return Some(entry)
    }
  }
  None
}

///|
fn zip_le_u16(data : Bytes, offset : Int) -> Int {
  data[offset].to_int() + data[offset + 1].to_int() * 256
}

///|
fn zip_le_u32_int(data : Bytes, offset : Int) -> Int {
  data[offset].to_int() +
  data[offset + 1].to_int() * 256 +
  data[offset + 2].to_int() * 65536 +
  data[offset + 3].to_int() * 16777216
}

///|
fn zip_le_u32_i64(data : Bytes, offset : Int) -> Int64 {
  Int64::from_int(data[offset].to_int()) +
  Int64::from_int(data[offset + 1].to_int()) * 256L +
  Int64::from_int(data[offset + 2].to_int()) * 65536L +
  Int64::from_int(data[offset + 3].to_int()) * 16777216L
}

///|
async fn expect_no_args(args : ArrayView[String], usage : String) -> Bool {
  if args.is_empty() {
    true
  } else {
    eprintln(usage)
    false
  }
}

///|
async fn usage_main() -> Unit {
  eprintln("usage: moon run --target native scripts/check_ci.mbtx [--skip-without-credentials]")
  eprintln("       moon run --target native scripts/check_ci.mbtx <check-subcommand>")
}

///|
async fn usage_check_ci() -> Unit {
  eprintln("usage: moon run --target native scripts/check_ci.mbtx [--skip-without-credentials]")
}

///|
async fn eprintln(message : String) -> Unit {
  write_stderr(message + "\n")
}

///|
async fn write_stderr(message : String) -> Unit {
  @stdio.stderr.write(message)
}

///|
async fn write_stdout(message : String) -> Unit {
  @stdio.stdout.write(message)
}
