import {
  "moonbitlang/async@0.19.0",
  "moonbitlang/async@0.19.0/fs",
  "moonbitlang/async@0.19.0/process",
  "moonbitlang/async@0.19.0/stdio",
  "moonbitlang/core/argparse",
  "moonbitlang/core/buffer",
  "moonbitlang/core/encoding/utf8",
  "moonbitlang/core/env",
  "moonbitlang/core/json",
  "moonbitlang/x@0.4.43/crypto",
}

///|
async fn main {
  let all_args = @env.args()
  let args = if all_args.is_empty() { all_args[:] } else { all_args[1:] }
  validate_args(args)
  let code = dispatch(args)
  if code != 0 {
    fail("check_ci failed")
  }
}

///|
async fn validate_args(args : ArrayView[String]) -> Unit {
  let command = check_ci_command()
  let _ = command.parse(argv=args, env={}) catch {
    error => {
      eprintln(error.to_string())
      usage_main()
      fail("invalid arguments")
    }
  }
}

///|
fn check_ci_command() -> @argparse.Command {
  @argparse.Command(
    "check_ci",
    about="Run repository validation checks.",
    flags=[
      @argparse.FlagArg(
        "skip-without-credentials",
        long="skip-without-credentials",
      ),
    ],
    subcommands=[
      check_ci_subcommand(),
      check_no_arg_subcommand("check-release-version"),
      check_no_arg_subcommand("check-scripts"),
      check_no_arg_subcommand("check-validation-inventory"),
      check_no_arg_subcommand("check-github-workflows"),
      check_no_arg_subcommand("check-source-layout"),
      check_no_arg_subcommand("check-test-inventory"),
      check_no_arg_subcommand("check-moonbit-style"),
      check_no_arg_subcommand("check-gitignore"),
      check_no_arg_subcommand("check-githooks"),
      check_no_arg_subcommand("check-migration-docs"),
      @argparse.Command(
        "check-fixture-sync",
        flags=[@argparse.FlagArg("require-reference", long="require-reference")],
      ),
      check_no_arg_subcommand("check-fixture-manifest"),
      check_no_arg_subcommand("check-package-metadata"),
      check_no_arg_subcommand("check-interfaces"),
      check_no_arg_subcommand("check-tests"),
      check_no_arg_subcommand("check-coverage"),
      check_no_arg_subcommand("smoke-native-cli"),
      check_no_arg_subcommand("check-cram-cli"),
      @argparse.Command(
        "verify-mooncakes-package",
        flags=[
          @argparse.FlagArg(
            "skip-without-credentials",
            long="skip-without-credentials",
          ),
        ],
      ),
      @argparse.Command(
        "check-publish-archive",
        positionals=[
          @argparse.PositionArg(
            "zip-path",
            num_args=@argparse.ValueRange(lower=0, upper=1),
          ),
        ],
      ),
    ],
    disable_help_subcommand=true,
  )
}

///|
fn check_ci_subcommand() -> @argparse.Command {
  @argparse.Command(
    "check-ci",
    flags=[
      @argparse.FlagArg(
        "skip-without-credentials",
        long="skip-without-credentials",
      ),
    ],
  )
}

///|
fn check_no_arg_subcommand(name : String) -> @argparse.Command {
  @argparse.Command(name)
}

///|
async fn dispatch(args : ArrayView[String]) -> Int {
  if args.is_empty() || args[0].has_prefix("--") {
    return check_ci(args)
  }
  let command = args[0]
  let rest = args[1:]
  match command {
    "check-ci" => check_ci(rest)
    "check-release-version" => check_release_version(rest)
    "check-scripts" => check_scripts(rest)
    "check-validation-inventory" => check_validation_inventory(rest)
    "check-github-workflows" => check_github_workflows(rest)
    "check-source-layout" => check_source_layout(rest)
    "check-test-inventory" => check_test_inventory(rest)
    "check-moonbit-style" => check_moonbit_style(rest)
    "check-gitignore" => check_gitignore(rest)
    "check-githooks" => check_githooks(rest)
    "check-migration-docs" => check_migration_docs(rest)
    "check-fixture-sync" => check_fixture_sync(rest)
    "check-fixture-manifest" => check_fixture_manifest(rest)
    "check-package-metadata" => check_package_metadata(rest)
    "check-interfaces" => check_interfaces(rest)
    "check-tests" => check_tests(rest)
    "check-coverage" => check_coverage(rest)
    "smoke-native-cli" => smoke_native_cli(rest)
    "check-cram-cli" => check_cram_cli(rest)
    "verify-mooncakes-package" => verify_mooncakes_package(rest)
    "check-publish-archive" => check_publish_archive(rest)
    _ => {
      usage_main()
      2
    }
  }
}

///|
async fn check_ci(args : ArrayView[String]) -> Int {
  let skip_mooncakes_without_credentials = match args.length() {
    0 => false
    1 => if args[0] == "--skip-without-credentials" {
      true
    } else {
      usage_check_ci()
      return 2
    }
    _ => {
      usage_check_ci()
      return 2
    }
  }

  let mut code = run_step("Check release version consistency", run_check_release_version)
  if code != 0 { return code }
  code = run_step("Check validation scripts", run_check_scripts)
  if code != 0 { return code }
  code = run_step("Check validation inventory", run_check_validation_inventory)
  if code != 0 { return code }
  code = run_step("Check GitHub workflows", run_check_github_workflows)
  if code != 0 { return code }
  code = run_step("Check source layout", run_check_source_layout)
  if code != 0 { return code }
  code = run_step("Check MoonBit test inventory", run_check_test_inventory)
  if code != 0 { return code }
  code = run_step("Check MoonBit source style", run_check_moonbit_style)
  if code != 0 { return code }
  code = run_step("Check gitignore", run_check_gitignore)
  if code != 0 { return code }
  code = run_step("Check git hooks", run_check_githooks)
  if code != 0 { return code }
  code = run_step("Check migration docs", run_check_migration_docs)
  if code != 0 { return code }
  code = run_step("Check vendored fixture sync", () => run_check_fixture_sync(false))
  if code != 0 { return code }
  code = run_step("Check vendored fixture manifest", run_check_fixture_manifest)
  if code != 0 { return code }
  code = run_step("Check package metadata", run_check_package_metadata)
  if code != 0 { return code }
  code = run_step("Check formatting", () => @process.run("moon", ["fmt", "--check"]))
  if code != 0 { return code }
  code = run_step("Check generated interfaces", run_check_interfaces)
  if code != 0 { return code }
  code = run_step("Type check default target", () =>
    @process.run("moon", ["check", "--warn-list", "+73"]))
  if code != 0 { return code }
  code = run_step("Type check all targets", () =>
    @process.run("moon", ["check", "--target", "all", "--warn-list", "+73"]))
  if code != 0 { return code }
  code = run_step("Type check native CLI", () =>
    @process.run("moon", ["check", "--target", "native", "cmd/main", "--warn-list", "+73"]))
  if code != 0 { return code }
  code = run_step("Run tests with count floor", run_check_tests)
  if code != 0 { return code }
  code = run_step("Analyze coverage", run_check_coverage)
  if code != 0 { return code }
  code = run_step("Build and smoke test native CLI", run_smoke_native_cli)
  if code != 0 { return code }
  code = run_step("Run Moon Cram native CLI tests", run_check_cram_cli)
  if code != 0 { return code }
  run_step(
    "Verify Mooncakes package",
    () => run_verify_mooncakes_package(skip_mooncakes_without_credentials),
  )
}

///|
async fn run_step(label : String, check : async () -> Int) -> Int {
  write_stdout("\n==> " + label + "\n")
  check()
}

