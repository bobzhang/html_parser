///|
#borrow(command)
extern "C" fn c_system(command : Bytes) -> Int = "system"

///|
#borrow(data)
extern "C" fn c_write(fd : Int, data : Bytes, count : Int) -> Int = "write"

///|
extern "C" fn c_exit(code : Int) -> Unit = "exit"

///|
fn main {
  let all_args = @env.args()
  let args = if all_args.is_empty() { all_args[:] } else { all_args[1:] }
  let code = dispatch(args)
  if code != 0 {
    c_exit(code)
  }
}

///|
fn dispatch(args : ArrayView[String]) -> Int {
  if args.is_empty() || args[0].has_prefix("--") {
    return check_ci(args)
  }
  let command = args[0]
  let rest = args[1:]
  match command {
    "check-ci" => check_ci(rest)
    "check-release-version" => check_release_version(rest)
    "check-scripts" => check_scripts(rest)
    "check-validation-inventory" => check_validation_inventory(rest)
    "check-github-workflows" => check_github_workflows(rest)
    "check-source-layout" => check_source_layout(rest)
    "check-test-inventory" => check_test_inventory(rest)
    "check-moonbit-style" => check_moonbit_style(rest)
    "check-gitignore" => check_gitignore(rest)
    "check-githooks" => check_githooks(rest)
    "check-migration-docs" => check_migration_docs(rest)
    "check-fixture-sync" => check_fixture_sync(rest)
    "check-fixture-manifest" => check_fixture_manifest(rest)
    "check-package-metadata" => check_package_metadata(rest)
    "check-interfaces" => check_interfaces(rest)
    "check-tests" => check_tests(rest)
    "check-coverage" => check_coverage(rest)
    "smoke-native-cli" => smoke_native_cli(rest)
    "check-scrut-cli" => check_scrut_cli(rest)
    "verify-mooncakes-package" => verify_mooncakes_package(rest)
    "check-publish-archive" => check_publish_archive(rest)
    _ => {
      usage_main()
      2
    }
  }
}

///|
fn check_ci(args : ArrayView[String]) -> Int {
  let skip_mooncakes_without_credentials = match args.length() {
    0 => false
    1 => if args[0] == "--skip-without-credentials" {
      true
    } else {
      usage_check_ci()
      return 2
    }
    _ => {
      usage_check_ci()
      return 2
    }
  }

  let mut code = run_step("Check release version consistency", run_check_release_version)
  if code != 0 { return code }
  code = run_step("Check validation scripts", run_check_scripts)
  if code != 0 { return code }
  code = run_step("Check validation inventory", run_check_validation_inventory)
  if code != 0 { return code }
  code = run_step("Check GitHub workflows", run_check_github_workflows)
  if code != 0 { return code }
  code = run_step("Check source layout", run_check_source_layout)
  if code != 0 { return code }
  code = run_step("Check MoonBit test inventory", run_check_test_inventory)
  if code != 0 { return code }
  code = run_step("Check MoonBit source style", run_check_moonbit_style)
  if code != 0 { return code }
  code = run_step("Check gitignore", run_check_gitignore)
  if code != 0 { return code }
  code = run_step("Check git hooks", run_check_githooks)
  if code != 0 { return code }
  code = run_step("Check migration docs", run_check_migration_docs)
  if code != 0 { return code }
  code = run_step("Check vendored fixture sync", fn() { run_check_fixture_sync("") })
  if code != 0 { return code }
  code = run_step("Check vendored fixture manifest", run_check_fixture_manifest)
  if code != 0 { return code }
  code = run_step("Check package metadata", run_check_package_metadata)
  if code != 0 { return code }
  code = run_step("Check formatting", fn() { run_command("moon fmt --check") })
  if code != 0 { return code }
  code = run_step("Check generated interfaces", run_check_interfaces)
  if code != 0 { return code }
  code = run_step("Type check default target", fn() { run_command("moon check --warn-list +73") })
  if code != 0 { return code }
  code = run_step("Type check all targets", fn() { run_command("moon check --target all --warn-list +73") })
  if code != 0 { return code }
  code = run_step("Type check native CLI", fn() { run_command("moon check --target native cmd/main --warn-list +73") })
  if code != 0 { return code }
  code = run_step("Run tests with count floor", run_check_tests)
  if code != 0 { return code }
  code = run_step("Analyze coverage", run_check_coverage)
  if code != 0 { return code }
  code = run_step("Build and smoke test native CLI", run_smoke_native_cli)
  if code != 0 { return code }
  code = run_step("Run Scrut native CLI tests", run_check_scrut_cli)
  if code != 0 { return code }
  run_step(
    "Verify Mooncakes package",
    fn() { run_verify_mooncakes_package(skip_mooncakes_without_credentials) },
  )
}

///|
fn run_step(label : String, check : () -> Int) -> Int {
  write_stdout("\n==> " + label + "\n")
  check()
}

///|
fn check_release_version(args : ArrayView[String]) -> Int {
  if !expect_no_args(args, "usage: moon run --target native scripts/check_ci.mbtx check-release-version") { return 2 }
  run_check_release_version()
}

