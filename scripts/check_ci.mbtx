///|
fn run_command(command : String) -> Int {
  if c_system(@utf8.encode(command)) == 0 { 0 } else { 1 }
}

///|
fn run_bash(script : String) -> Int {
  run_command("bash -euo pipefail -c " + shell_quote(script))
}

///|
fn run_python(source : String, args : String) -> Int {
  let command = if args.is_empty() {
    "python3 - <<'PY'\n" + source + "\nPY"
  } else {
    "python3 - " + args + " <<'PY'\n" + source + "\nPY"
  }
  run_bash(command)
}

///|
fn expect_no_args(args : ArrayView[String], usage : String) -> Bool {
  if args.is_empty() {
    true
  } else {
    eprintln(usage)
    false
  }
}

///|
fn usage_main() -> Unit {
  eprintln("usage: moon run --target native scripts/check_ci.mbtx [--skip-without-credentials]")
  eprintln("       moon run --target native scripts/check_ci.mbtx <check-subcommand>")
}

///|
fn usage_check_ci() -> Unit {
  eprintln("usage: moon run --target native scripts/check_ci.mbtx [--skip-without-credentials]")
}

///|
fn eprintln(message : String) -> Unit {
  write_stderr(message + "\n")
}

///|
fn write_stderr(message : String) -> Unit {
  let data = @utf8.encode(message)
  let _ = c_write(2, data, data.length())
}

///|
fn write_stdout(message : String) -> Unit {
  let data = @utf8.encode(message)
  let _ = c_write(1, data, data.length())
}

///|
fn shell_join(values : ArrayView[String]) -> String {
  let out = @buffer.new()
  let mut first = true
  for value in values {
    if first {
      first = false
    } else {
      out.write_string(" ")
    }
    out.write_string(shell_quote(value))
  }
  out.to_string()
}

///|
fn shell_quote(value : String) -> String {
  if value.is_empty() {
    return "''"
  }
  let out = @buffer.new()
  out.write_string("'")
  for ch in value.iter() {
    if ch == '\'' {
      out.write_string("'\\''")
    } else {
      out.write_char(ch)
    }
  }
  out.write_string("'")
  out.to_string()
}

