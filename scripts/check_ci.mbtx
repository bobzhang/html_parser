///|
async fn run_smoke_native_cli() -> Int {
  let build_code = @process.run(
    "moon",
    ["run", "--target", "native", "--release", "--build-only", "cmd/justhtml"],
  )
  if build_code != 0 {
    return build_code
  }
  let cli = "_build/native/release/build/bobzhang/html_parser/cmd/justhtml/justhtml.exe"
  if !@fs.exists(cli) {
    eprintln("native CLI binary was not built: \{cli}")
    return 1
  }
  let tmpdir = @fs.tmpdir(prefix="html_parser_check_ci")
  let smoke_input = "\{tmpdir}/smoke.html"
  @fs.write_file(
    smoke_input,
    "<article><p>Hi <b>there</b></p><p>Bye</p></article>",
    create_mode=CreateOrTruncate,
  )
  let (text_code, text_out, text_err) = @process.collect_output(
    cli,
    [smoke_input, "--selector", "p", "--format", "text"],
  )
  if text_code != 0 {
    eprintln(text_err.text())
    cleanup_tmpdir(tmpdir)
    return text_code
  }
  if text_out.text() != "Hi there\nBye\n" {
    eprintln("unexpected text extraction output:")
    eprintln(text_out.text())
    cleanup_tmpdir(tmpdir)
    return 1
  }
  let empty_input = "\{tmpdir}/empty.html"
  @fs.write_file(empty_input, "<p>Hello</p>", create_mode=CreateOrTruncate)
  let (empty_code, empty_out, empty_err) = @process.collect_output(
    cli,
    [empty_input, "--selector", ".does-not-exist"],
  )
  if empty_code != 1 || !empty_out.text().is_empty() {
    eprintln("missing-selector smoke test expected exit code 1 and empty stdout")
    eprintln(empty_err.text())
    cleanup_tmpdir(tmpdir)
    return 1
  }
  let (wiki_code, wiki_out, wiki_err) = @process.collect_output(
    cli,
    ["tests/fixtures/justhtml/data/wikipedia.html", "--format", "markdown"],
  )
  if wiki_code != 0 {
    eprintln(wiki_err.text())
    cleanup_tmpdir(tmpdir)
    return wiki_code
  }
  let wikipedia = wiki_out.text()
  match first_nonblank_line(wikipedia) {
    Some(line) => if !line.has_prefix("<img") {
      eprintln("Expected Wikipedia Markdown to start with body image, got: \{line}")
      cleanup_tmpdir(tmpdir)
      return 1
    }
    None => {
      eprintln("Wikipedia Markdown output was empty")
      cleanup_tmpdir(tmpdir)
      return 1
    }
  }
  let markdown_needles = [
    "The Free Encyclopedia",
    "(https://en.wikipedia.org/)",
    "[Wikiquote Free quote compendium](https://www.wikiquote.org/)",
    "[MediaWiki Free &amp; open wiki software](https://www.mediawiki.org/)",
    "[Wikisource Free content library](https://www.wikisource.org/)",
    "[Wikispecies Free species directory](https://species.wikimedia.org/)",
    "[Wikifunctions Free function library](https://www.wikifunctions.org/)",
    "[Meta-Wiki Community coordination &amp; documentation](https://meta.wikimedia.org/)",
  ]
  for needle in markdown_needles {
    if !wikipedia.contains(needle) {
      eprintln("Wikipedia Markdown output is missing: \{needle}")
      cleanup_tmpdir(tmpdir)
      return 1
    }
  }
  cleanup_tmpdir(tmpdir)
  0
}

